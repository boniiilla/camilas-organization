generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Asignatura {
  id         String   @id @default(uuid())
  nombre     String
  color      String
  profesor   String?
  created_at DateTime @default(now())
  tareas     Tarea[]
  examenes   Examen[]

  @@map("asignaturas")
}

model Tarea {
  id             String     @id @default(uuid())
  asignatura_id  String
  titulo         String
  descripcion    String?
  fecha          String
  hecha          Boolean    @default(false)
  archivos       Json?
  created_at     DateTime   @default(now())
  asignatura     Asignatura @relation(fields: [asignatura_id], references: [id], onDelete: Cascade)
  subtareas      SubTarea[]

  @@map("tareas")
}

model SubTarea {
  id         String   @id @default(uuid())
  tarea_id   String
  titulo     String
  hecha      Boolean  @default(false)
  created_at DateTime @default(now())
  tarea      Tarea    @relation(fields: [tarea_id], references: [id], onDelete: Cascade)

  @@map("sub_tareas")
}

model Examen {
  id             String     @id @default(uuid())
  asignatura_id  String
  titulo         String
  fecha          String
  nota           Float?
  detalles       String?
  archivos       Json?
  created_at     DateTime   @default(now())
  asignatura     Asignatura @relation(fields: [asignatura_id], references: [id], onDelete: Cascade)

  @@map("examenes")
}

model User {
  id                 String             @id @default(uuid())
  username           String             @unique
  password           String
  email              String?            @unique
  avatar_url         String?
  created_at         DateTime           @default(now())
  push_subscriptions PushSubscription[]
  reminders          Reminder[]
  manual_reminders   ManualReminder[]

  @@map("users")
}

model PushSubscription {
  id         String   @id @default(uuid())
  user_id    String
  endpoint   String   @unique
  p256dh     String
  auth       String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model CosaQuHacer {
  id             String   @id @default(uuid())
  titulo         String
  descripcion    String?
  completada     Boolean  @default(false)
  fecha_creacion DateTime @default(now())
  prioridad      String   @default("media")

  @@map("cosas_qu_hacer")
}

model Reminder {
  id           String   @id @default(uuid())
  user_id      String
  type         String
  reference_id String
  title        String
  due_date     String
  mode         String
  remind_from  String?
  remind_until String?
  remind_time  String?  @default("09:00")
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([reference_id, type])
  @@map("reminders")
}

model ManualReminder {
  id           String   @id @default(uuid())
  user_id      String
  title        String
  description  String?
  remind_from  String?
  remind_until String?
  remind_time  String?  @default("09:00")
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("manual_reminders")
}
